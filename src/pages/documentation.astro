---
import BaseLayout from "../layouts/BaseLayout.astro";
import DigitalBackground from "../components/DigitalBackground.astro";

import TimelineSection from "../components/TimelineSection.svelte"

const title = "Documentation";
import PageHead from "../components/PageHead.astro";

import { Image } from "astro:assets";

---

<BaseLayout title={title}>
    <PageHead h1={title}/>
    <DigitalBackground>
    
        <iframe width="300" height="400" src="https://docs.google.com/document/d/e/2PACX-1vSBW-XKQmvC0N_YXJayXSzY9tdKdDJl1VQuqizFO21sd2MO6JbePKGmF2EP0yYDINXeIjhVVpM8c2j4/pub?embedded=true">
        </iframe>

        <div>
            <p>Project Version:</p>
            <p>2.00.4</p>
        </div>

        <Image
            src="/documentation_1.png"
            alt=""
            width="1920"
            height="800"
        />
    </DigitalBackground>

    <TimelineSection client:load />


</BaseLayout>

