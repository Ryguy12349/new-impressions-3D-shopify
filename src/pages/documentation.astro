---
import BaseLayout from "../layouts/BaseLayout.astro";
import DigitalBackground from "../components/DigitalBackground.astro";

import TimelineSection from "../components/TimelineSection.svelte"

const title = "Documentation";
import PageHead from "../components/PageHead.astro";

import { Image } from "astro:assets";

---

<BaseLayout title={title}>
    <PageHead h1={title}/>
    <DigitalBackground>
        
        <div id="doc_wrapper">
            <iframe width="300" height="400" src="https://docs.google.com/document/d/e/2PACX-1vSBW-XKQmvC0N_YXJayXSzY9tdKdDJl1VQuqizFO21sd2MO6JbePKGmF2EP0yYDINXeIjhVVpM8c2j4/pub?embedded=true">
            </iframe>
        </div>
        <div id="project_version">
            <p>Project Version:</p>
            <p>2.00.4</p>
        </div>

        <Image
            id="docImg"
            src="/documentation_1.png"
            alt=""
            width="1920"
            height="800"
        />
    </DigitalBackground>

    <TimelineSection client:load />


</BaseLayout>

<style>

    #doc_wrapper {

        position: relative;
        width: 100%; /* Your desired visible size */
        height: 380px;
        overflow: hidden;
    }

    iframe {
        width: 333%;
        height: 1140px; 
        transform: scale(0.333);
        transform-origin: 0 0;
    }

    #project_version{
        margin-top: 3rem;
        display: flex;
        width: 100%;
        flex-flow: row nowrap;
        justify-content: center;
        align-items: center;
        gap: 1rem;
    }

    #project_version p:nth-child(1) {
        font-family: 'Montserrat Variable';
        font-size: 1.5rem;
        font-weight: 500;
        padding: 0 0 .1rem;
        color: var(--color-digital-content);
    }

    #project_version p:nth-child(2) {
        font-family: 'Courier New', Courier, monospace;
        font-size: 1.5rem;
        font-weight: bold;
        color: var(--color-digital-content);
    }

    @media (min-width: 700px) {
        #doc_wrapper {
            width: 50%;
            height: 650px;
            overflow-x: hidden;
            margin:0 auto;
        }

        iframe {
            width: 110%;
            height: 650px; 
            transform: scale(1);
        }

        #docImg {
            width: 75%;
            margin: 0 auto;
        }
    }
</style>