---
import BaseLayout from "../layouts/BaseLayout.astro";
import DigitalBackground from "../components/DigitalBackground.astro";

import Image from "astro/components/Image.astro";
import LinkBtn from "../components/linkbtn.astro";

const title = "About";
import PageHead from "../components/PageHead.astro";

---

<BaseLayout title={title}>
    <PageHead h1={title}/>
    <DigitalBackground>
        <div id="about_digi" class="grid grid-cols-3 gap-8 justify-items-center">
            <!-- <span><p class="about_digi_text ">Design</p></span> -->
            <Image
                src="/about_2.png"
                alt="Initial Design for typepieces"
                class="img_left "
                width="600"
                height="600"
            />
            <!-- <span><p class="about_digi_text ">Test</p></span> -->
            <Image
                src="/about_1.png"
                alt="Test Prints, showing the joy of miss spelling when printing: TMIE(time) For Design"
                class="img_right "
                width="600"
                height="600"
            />
            <!-- <span><p class="about_digi_text ">Play</p></span> -->
            <Image
                src="/about_4.webp"
                alt="Design play, test styles for documentation branding"
                class="img_left "
                width="600"
                height="600"
            />
            <!-- <span><p class="about_digi_text ">Document</p></span> -->
            <Image
                src="/about_3.webp"
                alt="Design play, test styles for documentation branding"
                class="img_right "
                width="600"
                height="600"
            />

        </div>
    </DigitalBackground>
    <section id="started" class="paper_section">
        <div class="text_container">
            <div>
                <h2>Where it started</h2>
                <p>
                    This project started with the question, “What are you going to do for your thesis?” 
                    My answer, of course, my answer was “I don’t know, probably something with my collection of quotes in my notes app.” 
                    Kick off to a week later, and the realization that I spent my whole savings on a 3D printer, 
                    it became clear to me that I need to use my printer to connect my major thesis with my DDF minor.
                </p>
                <p>
                    The connection between major and minor skills led me down the path to a documentary project now known a New Impressions. 
                    Documenting my growth in connecting and combining skills through the goal my building an almost fully 3D printed letterpress. 
                    This letterpress would work both with old letterpress equipment and would have a full set of its own tools.
                </p>
            </div>
        </div>
    </section>
    <section id="intents" class="paper_section">
        <div class="text_container">
            <div>
                <h2>Intents & Goals</h2>
                <p>
                    New Impressions is a project based on the idea of creating a cheap, highly portable, 
                    letterpress setup from typepieces to quoin to the press itself. 
                    All of this needed to be 3D printable and devoid of lead.
                </p>
            </div>
            <div class="two_links">
                <LinkBtn url="https://2026show.newpaltz.design/projects/new-impressions/">View my<br/> project page</LinkBtn>
                <LinkBtn url="https://2026show.newpaltz.design/">View our<br/> class page</LinkBtn>
            </div>
        </div>
    </section> 
    <section id="achievements" class="paper_section"> 
        <div class="text_container">
            <h2>Achievements</h2>
                <ul>
                    <li></li>
                    <li></li>
                    <li></li>
                    <li></li>
                    <li></li>
                </ul>
        </div>
    </section>  
</BaseLayout>

<style>
    #about_digi {
        padding: 0 .5rem
    }

    #about_digi img {
        grid-column: 1 / 4;
        object-fit: cover;
        max-height: 600px;
        margin: 0 0 4rem;
    }

    span:has(.about_digi_text) {
        grid-column: 1 / 4;
        width: 100%;
        text-align: left;
        border-bottom: 1px solid var(--color-digital-content);
    }

    .about_digi_text {
        margin: 0;
        padding-left: 2rem;
        color: var(--color-digital-content);
        font-family: 'Montserrat Variable';
        font-weight: 700;
        font-size: clamp(2rem, 5vw, 10rem);
    }

    p {
        margin-bottom: .25rem;
    }

    @media (min-width: 700px ){
        #about_digi {
            padding: 0 10rem;
        }

        #about_digi .img_right {
            grid-column: 2 / 4;
        }

        #about_digi .img_left {
            grid-column: 1 / 3;
        }
    }
</style>
