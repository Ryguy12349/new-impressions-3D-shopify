---
import DigitalBackground from "../components/DigitalBackground.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Q&A";
import PageHead from "../components/PageHead.astro";

---

<BaseLayout title={title}>
<PageHead h1={title}/>
<div class="text_container">
    Don’t want to build the press, and our prebuilt options aren’t enough! Make a custom request
    Send Us a Custom Request
</div>
<DigitalBackground>
    <div class="email-form text_container">
        <h2>Send Me a Message</h2>
        <p>Email us at our own email service at ******@newimpression.com, or fill out this form. If you need some guidance on what to write to us, look below and find our guide on what we need to know from you.</p>
        <form name="contact" method="POST" netlify?>
            <div class="contact-sender-info">
                <div class="contact-name-box">
                    <label for="name" class="contact-label">Name:</label>
                    <input type="text" id="name" name="name" class="contact-input" required>
                </div>
                <div class="contact-email-box">
                    <label for="email" class="contact-label">Email:</label>
                    <input type="email" id="email" name="email" class="contact-input" required>
                </div>
            </div>
            <div class="contact-message-box">
                <label for="message" class="contact-label">Message:</label>
                <textarea id="message" name="message" rows="4" class="contact-input" required></textarea>
            </div>
            <div class="contact-submit-box">
                <input type="submit" id="submit" value="Submit">
            </div>
        </form>
    </div>
</DigitalBackground>

</BaseLayout>

<style>
     .email-form{
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .email-form form{
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: 60%;
    }

    .email-form h2, .email-form p {
        color: var(--color-digital-content);
    }

    #message {
        resize: vertical;
    }

    #name, #email, #message {
        width: 100%;
    }

    #submit {
        padding: .5rem 1rem;
        border: 1px solid var(--color-digital-content);
        border-radius: 5px;
        background-color: var(--color-digital-bg);
        color: var(--color-digital-content);
        font-family: 'faustina variable', serif;
        font-weight: bold;
    }

    #submit:hover {
        background-color: var(--color-digital-content);
        color: var(--color-digital-bg);
    }

    .contact-submit-box {
        align-self: flex-end;

    }

    .contact-sender-info {
        display: flex;
        flex-direction: row;
        gap: .5rem;
    }

    .contact-name-box, .contact-email-box  {
        position: relative;
        margin-bottom: .5rem;
        color: var(--color-digital-content);
    }

    .contact-message-box {
        position: relative;
        color: var(--color-digital-content);
    }

    .contact-label {
        position: absolute;
        top: -.75rem;
        left: .75rem;
        font-family: 'faustina variable', serif;
        font-weight: bold;
        color: var(--color-digital-content);
        background-color: var(--color-digital-bg);
        padding: 0 .5rem;
    }

    .contact-input{
        font-family: 'faustina variable', serif;
        background-color: var(--color-digital-bg);
        border: 1px solid var(--color-digital-content);
        border-radius: 5px;
        padding: .5rem;
    }

    @media (max-width: 470px) {
        .contact-sender-info {
            flex-direction: column;
        }

        .business-card-scene {
            --card-width: 280px;
        }
    
        #submit{
            font-size: 1rem;
        }

        .email-form form{
            width: 100%;
        }
    }
</style>
