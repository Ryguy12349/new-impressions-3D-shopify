<style>
    .digital-background {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        background-color: var(--color-digital-bg);
        object-fit: cover;
        background-size: 150%;
        background-position: 25% 10%;
    }

    #toBeMasked {
        width:100%;
        height: fit-content;
        z-index: 0;
    }

    .maskTop {
        -webkit-mask-image: url(/digital-background-paper-rip-top.svg);
        mask-image: url(/digital-background-paper-rip-top.svg);
        mask-repeat: no-repeat;    
    }

    .maskBot {
        -webkit-mask-image: url(/digital-background-paper-rip-bottom.svg);
        mask-image: url(/digital-background-paper-rip-bottom.svg);
        mask-repeat: no-repeat;   
    }
</style>