---
const { h1 = "" } = Astro.props;

import Image from "astro/components/Image.astro";

const imageMap = {
  "About": "/pageHeads/about_header.webp",
  "Build It": "/pageHeads/build_it_header.webp",
  "Documentation": "/pageHeads/documentation_header.webp",
  "Letterpress": "/pageHeads/letterpress_header.webp",
  "Q&A": "/assets/pageHeads/qa_header.webp",
  "Shop": "/pageHeads/shop_header.webp",
  "Type Pieces": "/pageHeads/typepieces_header.webp",
  "Inspirations": "/pageHeads/inspo_header.webp",
  "Terms & Services": "/pageHeads/terms_and_services_header.webp"
};

const imageSrc = imageMap[h1] ?? "/pageHeads/about_header.webp";
---

<script>
  const h1El = document.querySelector("#hero-title");

  if (h1El) {
    const text = h1El.textContent || "";
    const h1charlen = text.length;
    const h1width = h1El.offsetWidth;

    if (h1charlen > 0) {
      const calculatedSize = (h1width / h1charlen);
      
      if (calculatedSize < 30) {
        const quickmath = calculatedSize + 8;
        h1El.style.fontSize = `${quickmath}px`;
      } else {
        h1El.style.fontSize = `${calculatedSize}px`;
      }
    }
  }
</script>

<section id="hero">
  <Image src={imageSrc} alt="" width="800px" height="800px"/>
  <h1 id="hero-title" >{h1}</h1>
</section>

<style>

  section {
    display: grid;
    grid-template-rows: repeat(3, 1fr) 2rem;
    grid-template-columns: repeat(12, 1fr);
  }

  h1 {
    grid-area: 3 / 2 / 4 / 12;
    font-size: 2rem;  
  }

  section#hero img {
    grid-area: 1 / 3 / 4 / 11;
  }

 @media (min-width: 700px ) {
  section {

    max-height: 80vh;
  }

  h1 {
    grid-area: 1 / 2 / 3 / 12;
    font-size: 2rem;  
  }

  section#hero img {
    grid-area: 1 / 7 / 4 / 11;
  }
 }
</style>