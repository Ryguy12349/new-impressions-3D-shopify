---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CartDrawer from "../components/cart/CartDrawer.svelte";
import AnnouncementBar from "../components/AnnouncementBar.astro";

export interface Props {
  title: string;
  description?: string;
}

const defaultDesc =
  "New Impressions is a open source 3D printing commerce storefront selling letterpress products.";

const { title, description = defaultDesc } = Astro.props as Props;
const tabTitle = `${title} | New Impressions`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{tabTitle}</title>
    <meta name="description" content={description} />
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body class="paper_pattern">
    <!-- <AnnouncementBar /> -->
    <CartDrawer client:idle />
    <Header title={title} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
